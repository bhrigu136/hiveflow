# ── Core (REQUIRED) ───────────────────────────────────────────────────────────
SECRET_KEY=your-long-random-secret-key-here

# ── Database ───────────────────────────────────────────────────────────────────
# Leave blank for local SQLite. Set this to your PostgreSQL URL in production.
# Render / Railway / Heroku will provide this automatically if you add a DB addon.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Google Calendar OAuth (Optional) ──────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com
# Add this redirect URI: http://127.0.0.1:5000/google/callback (local)
#                        https://yourdomain.com/google/callback (production)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ── Email (Verification + Password Reset) ─────────────────────────────────────
# Uses Brevo's HTTP API (https://www.brevo.com) — SMTP is blocked on most PaaS
# providers (Render, Heroku), so we send over HTTPS instead.
# 1. Sign up at brevo.com (free: 300 emails/day, no credit card)
# 2. Settings → SMTP & API → API Keys → create a key
# 3. Senders → add and verify your sending email
# If not set, the OTP code will flash on screen instead (fine for local dev).
# BREVO_API_KEY=your-brevo-api-key
# MAIL_SENDER=your-verified-sender@example.com

# ── Flask Environment ──────────────────────────────────────────────────────────
# Set to 'production' on your hosting platform
# FLASK_ENV=production

# ── Pusher WebSockets (Required for Real-time Chat) ───────────────────────────
# Create an account at https://pusher.com
PUSHER_APP_ID=your-pusher-app-id
PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=ap2

# ── Supabase Storage (Required for Presigned File Uploads) ────────────────────
# Create a storage bucket inside https://supabase.com
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key-here
SUPABASE_STORAGE_BUCKET=project-assets


